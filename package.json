{
  "name": "fairyland-ui",
  "version": "0.0.1",
  "description": "A ui project for fairyland",
  "productName": "Fairyland App",
  "author": "lishangbu <shangshili@hotmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js,.ts,.vue ./",
    "format": "prettier --write \"**/*.{js,ts,vue,css,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "proto": "pbjs -t static-module -w es6 --es6 --force-long -o src/generated/index.js src/proto/*.proto&&cd src/generated&&pbts index.js -o index.d.ts"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.13",
    "pinia": "^2.2.6",
    "pinia-plugin-persistedstate": "^4.1.3",
    "quasar": "^2.17.4",
    "vue": "^3.5.13",
    "vue-router": "^4.0.13"
  },
  "devDependencies": {
    "@quasar/app-vite": "^2.0.0-rc.1",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "prettier": "^3.3.3",
    "protobufjs": "^7.4.0",
    "typescript": "^5.6.3",
    "vite-plugin-checker": "^0.8.0",
    "vue-tsc": "^2.1.10"
  },
  "engines": {
    "node": "^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
